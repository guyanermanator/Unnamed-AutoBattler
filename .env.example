# Copy this file to .env and fill in the values
# Never commit .env to source control

# PostgreSQL connection string
DATABASE_URL=******localhost:5432/autobattler

# Docker Compose PostgreSQL credentials (used only by docker-compose)
POSTGRES_USER=autobattler
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=autobattler

# JWT signing secret — generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=CHANGE_ME

# Server port (optional, defaults to 3000)
PORT=3000
